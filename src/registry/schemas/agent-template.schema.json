{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "registry/agent-template.schema.json",
  "title": "AgentTemplate",
  "type": "object",
  "required": [
    "name",
    "role",
    "backstory",
    "goal",
    "core_objective",
    "individual_vision",
    "role_non_negotiable_requirements",
    "objectives_long_term",
    "personality_traits",
    "interaction_style",
    "constraints",
    "skills",
    "kpis",
    "protocols",
    "workflows"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 2 },
    "role": { "type": "string", "minLength": 2 },
    "backstory": { "type": "string", "minLength": 40 },
    "goal": {
      "oneOf": [
        { "type": "string", "minLength": 20 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 8 }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 8 }
        }
      ]
    },
    "core_objective": { "type": "string", "minLength": 12 },
    "individual_vision": { "type": "string", "minLength": 12 },
    "role_non_negotiable_requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 },
      "uniqueItems": true
    },
    "objectives_long_term": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 8 },
      "uniqueItems": true
    },
    "personality_traits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "interaction_style": { "type": "string", "minLength": 8 },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 },
      "uniqueItems": true
    },
    "deep_persona": {
      "type": "object",
      "description": "Optional deep persona contract for OpenCLAW-style execution constraints and behavior shaping.",
      "properties": {
        "personality_traits": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "uniqueItems": true
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 4 },
          "uniqueItems": true
        },
        "interaction_style": { "type": "string", "minLength": 4 },
        "delegation_limits": {
          "type": "object",
          "properties": {
            "max_depth": { "type": "integer", "minimum": 0 },
            "timeout_ms": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "skills": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "kpis": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "data_requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "protocols": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "hybrid_content": {
      "type": "object",
      "description": "Hybrid envelope supporting structured records and unstructured markdown sidecar content.",
      "properties": {
        "structured_payload": {
          "oneOf": [
            { "type": "object" },
            { "type": "array" },
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "unstructured_markdown": { "type": "string" },
        "source_format": { "type": "string", "enum": ["json", "yaml", "markdown", "mixed"] },
        "projection_target": { "type": "string", "enum": ["git", "sqlite", "vault", "memory-cache", "hybrid"] },
        "data_classification": { "type": "string", "enum": ["T1", "T2", "T3", "T4", "public", "internal", "confidential", "restricted"] },
        "sync_status": { "type": "string", "enum": ["PENDING", "COMMITTED", "REJECTED", "STALE"] },
        "canonical_source": { "type": "string", "enum": ["git", "vault", "registry"] },
        "ingest_timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "anyOf": [
    { "required": ["data"] },
    { "required": ["data_requirements"] }
  ],
  "additionalProperties": false
}
