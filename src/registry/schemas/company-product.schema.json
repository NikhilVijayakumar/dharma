{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "registry/company-product.schema.json",
  "title": "CompanyProduct",
  "description": "Product catalog with company-specific assignments, ownership, and development metadata.",
  "type": "object",
  "required": ["$schema", "companyId", "products", "productsOrder"],
  "properties": {
    "$schema": {
      "type": "string",
      "pattern": ".*company-product\\.schema\\.json$"
    },
    "companyId": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "products": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["details"],
        "properties": {
          "details": {
            "type": "string",
            "description": "Relative path to product details.json"
          },
          "documentation": {
            "type": "string",
            "description": "Relative path to product documentation.md"
          },
          "owner": {
            "type": "string",
            "description": "Agent ID of the product owner"
          },
          "stage": {
            "type": "string",
            "enum": ["planning", "mvp", "growth", "mature", "deprecated"],
            "description": "Current development stage"
          },
          "priorities": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Current priorities for this product"
          },
          "assignedKpis": {
            "type": "array",
            "items": { "type": "string" },
            "description": "KPI IDs assigned to this product"
          },
          "assignedProtocols": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Protocol IDs required for this product"
          },
          "assignedBranding": {
            "type": "string",
            "description": "Path to branding directory"
          },
          "metrics": {
            "type": "object",
            "description": "Product-specific success metrics",
            "additionalProperties": true
          },
          "developmentPlan": {
            "type": "object",
            "properties": {
              "currentPhase": {
                "type": "string",
                "enum": ["planning", "mvp", "growth", "mature"]
              },
              "targetLaunchDate": {
                "type": ["string", "null"],
                "format": "date"
              },
              "estimatedCost": {
                "type": ["number", "null"]
              },
              "roiTarget": {
                "type": ["number", "null"]
              }
            }
          }
        }
      }
    },
    "productsOrder": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Canonical ordering of products"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
