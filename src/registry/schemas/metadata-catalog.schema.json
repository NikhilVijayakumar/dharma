{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "registry/metadata-catalog.schema.json",
  "title": "MetadataCatalog",
  "description": "Generic metadata catalog for referencing global registry entries from a company context.",
  "type": "object",
  "required": ["$schema", "companyId", "entries"],
  "properties": {
    "$schema": {
      "type": "string",
      "pattern": ".*metadata-catalog\\.schema\\.json$"
    },
    "companyId": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "entries": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "description": "Relative path to the global registry entry"
      }
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
