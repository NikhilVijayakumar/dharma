{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "registry/kpi-minimum-requirements.schema.json",
  "title": "KpiMinimumRequirements",
  "type": "object",
  "required": ["version", "minimumRequirements"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "minimumRequirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stepId", "requiredFields"],
        "properties": {
          "stepId": { "type": "string", "minLength": 2 },
          "requiredFields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["key", "minWords", "quality"],
              "properties": {
                "key": { "type": "string", "minLength": 2 },
                "minWords": { "type": "number", "minimum": 1 },
                "quality": { "type": "string", "enum": ["required", "recommended"] }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "hybrid_content": {
      "type": "object",
      "description": "Hybrid envelope supporting structured requirement matrices and markdown annotations.",
      "properties": {
        "structured_payload": {
          "oneOf": [
            { "type": "object" },
            { "type": "array" },
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "unstructured_markdown": { "type": "string" },
        "source_format": { "type": "string", "enum": ["json", "yaml", "markdown", "mixed"] },
        "projection_target": { "type": "string", "enum": ["git", "sqlite", "vault", "memory-cache", "hybrid"] },
        "data_classification": { "type": "string", "enum": ["T1", "T2", "T3", "T4", "public", "internal", "confidential", "restricted"] },
        "sync_status": { "type": "string", "enum": ["PENDING", "COMMITTED", "REJECTED", "STALE"] },
        "canonical_source": { "type": "string", "enum": ["git", "vault", "registry"] },
        "ingest_timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
