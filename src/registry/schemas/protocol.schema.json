{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "registry/protocol.schema.json",
  "title": "Protocol",
  "type": "object",
  "required": ["id", "title", "description", "rules"],
  "properties": {
    "id": { "type": "string", "minLength": 2 },
    "title": { "type": "string", "minLength": 2 },
    "description": { "type": "string", "minLength": 8 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 4 },
          {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": { "type": "string", "minLength": 4 }
          }
        ]
      }
    },
    "automation_guards": {
      "type": "object",
      "description": "Optional automation guard metadata for runtime policies and approval gates.",
      "properties": {
        "selector_resolution": { "type": "object" },
        "interaction_retries": { "type": "object" },
        "timeout_policy": { "type": "object" },
        "approval_gate": { "type": "object" }
      },
      "additionalProperties": true
    },
    "navigation_rules": {
      "type": "object",
      "description": "Optional selector and navigation policy model inspired by NemoClaw automation patterns.",
      "properties": {
        "required_metadata": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "uniqueItems": true
        },
        "wait_policy": {
          "type": "object",
          "properties": {
            "allowed": {
              "type": "array",
              "items": { "type": "string", "minLength": 2 },
              "uniqueItems": true
            }
          },
          "additionalProperties": true
        },
        "fallback_strategy": { "type": "object" }
      },
      "additionalProperties": true
    },
    "hybrid_content": {
      "type": "object",
      "description": "Hybrid envelope supporting structured records and markdown annotations.",
      "properties": {
        "structured_payload": {
          "oneOf": [
            { "type": "object" },
            { "type": "array" },
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "unstructured_markdown": { "type": "string" },
        "source_format": { "type": "string", "enum": ["json", "yaml", "markdown", "mixed"] },
        "projection_target": { "type": "string", "enum": ["git", "sqlite", "vault", "memory-cache", "hybrid"] },
        "data_classification": { "type": "string", "enum": ["T1", "T2", "T3", "T4", "public", "internal", "confidential", "restricted"] },
        "sync_status": { "type": "string", "enum": ["PENDING", "COMMITTED", "REJECTED", "STALE"] },
        "canonical_source": { "type": "string", "enum": ["git", "vault", "registry"] },
        "ingest_timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
