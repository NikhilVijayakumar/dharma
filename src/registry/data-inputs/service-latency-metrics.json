          "OPERATIONAL": "200ms - 2s (Standard-Execution)",
          "DEFERRED": "2s - 30s (Complex-Synthesis)",
          "STALLED": "> 30s (Timeout-Risk)"
        }
      }
    },
    "source_format": "json",
    "projection_target": "hybrid",
