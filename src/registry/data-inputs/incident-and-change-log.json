        "event_states": {
          "CHANGE_PENDING": "Validation-Stage (Pre-Flight)",
          "INCIDENT_ACTIVE": "Degradation-Detected (Triage)",
          "REMEDIATED": "Stability-Restored (Post-Mortem)",
          "HARDENED": "Protocol-Updated (Immunized)"
        }
      }
    },
    "source_format": "json",
    "projection_target": "hybrid",
